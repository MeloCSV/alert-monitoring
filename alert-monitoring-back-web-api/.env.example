# Application
ENVIRONMENT=local
FWK_PATH=alert_monitoring/api

# Database (local — matches application-local.yml)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=alert_monitoring
DB_USER=sa
DB_PASSWORD=root

# Kubernetes clusters: JSON array of cluster objects
# Fields: name (str), host (str), token (str), namespace (str, default "prometheus"),
#         ca_cert (str|null), verify_ssl (bool, default true)
K8S_CLUSTERS=[{"name":"OCP","host":"https://api.example.com:6443","token":"<token>","namespace":"prometheus","verify_ssl":false}]

# AlertManager instances: JSON array of AlertManager objects
# Fields: name (str), url (str), token (str|null),
#         host_header (str|null)  — HTTP Host header sent with every request
#         sni_hostname (str|null) — TLS SNI override; only needed when the TLS
#                                   server requires an SNI that differs from the URL host
#                                   (e.g. connecting through an explicit TLS proxy).
#                                   Leave unset for plain kubectl port-forward.
#         verify_ssl (bool, default true)
ALERTMANAGERS=[{"name":"pro","url":"https://localhost:9443","host_header":"alertmanager-main.apps.example.com","token":"<token>","verify_ssl":false}]

# Kibana instances: JSON array of Kibana objects
# Fields: name (str), base_url (str), api_key (str), space_id (str|null),
#         verify_ssl (bool, default true), per_page (int, default 100), max_pages (int, default 100)
KIBANAS=[{"name":"gcp-prod","base_url":"https://kibana.example.com","api_key":"<api_key>","verify_ssl":true,"per_page":1000,"max_pages":50}]
