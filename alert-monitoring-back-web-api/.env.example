# Framework
ENVIRONMENT=local
FWK_PATH=alert_monitoring/api  # En Windows usar ruta absoluta: C:\...\alert_monitoring\api

# Base de datos (entorno local — ver application-local.yml)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=alert_monitoring
DB_USER=sa
DB_PASSWORD=root

# Clusters Kubernetes (JSON)
K8S_CLUSTERS=[{"name":"...","host":"...","token":"...","verify_ssl":false}]

# Kibana (JSON)
KIBANA_ELASTIC_GCP=[{"name":"...","base_url":"...","api_key":"...","verify_ssl":true,"per_page":1000,"max_pages":50}]
KIBANA_ELASTIC=[{"name":"...","base_url":"...","api_key":"...","space_id":"...","verify_ssl":true,"per_page":1000,"max_pages":50}]

# AlertManager (JSON)
ALERTMANAGERS=[{"name":"...","url":"...","host_header":"...","verify_ssl":false}]

# Atlassian Assets
ATLASSIAN_ASSETS_WORKSPACE_ID=
ATLASSIAN_ASSETS_EMAIL=
ATLASSIAN_ASSETS_TOKEN=
ATLASSIAN_ASSETS_OBJECT_TYPE_ID=
# ATLASSIAN_ASSETS_BASE_URL=https://api.atlassian.com/jsm/assets  (opcional)
# ATLASSIAN_ASSETS_PAGE_SIZE=100  (opcional)

# OpenTelemetry (requiere docker-compose-observability.yaml levantado)
OTEL_SERVICE_NAME=alert-monitoring-back-web-api
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:55681
OTEL_EXPORTER_OTLP_METRICS_ENDPOINT=http://localhost:55681/v1/metrics
OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf
OTEL_METRICS_EXPORTER=otlp
OTEL_TRACES_EXPORTER=otlp
OTEL_TRACES_SAMPLER=always_on
# Nivel de trazas: 0=app, 1=libs publicas, 2=libs privadas (por defecto: 0)
# FWK_TRACE_LEVEL=0
