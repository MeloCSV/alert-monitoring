# Application
ENVIRONMENT=local
FWK_PATH=alert_monitoring/api

# Database (local — matches application-local.yml)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=alert_monitoring
DB_USER=sa
DB_PASSWORD=root

# Kubernetes clusters: JSON array of cluster objects
# Fields: name (str), host (str), token (str), namespace (str, default "prometheus"),
#         ca_cert (str|null), verify_ssl (bool, default true)
K8S_CLUSTERS=[]

# Kibana instances: JSON array of Kibana objects
# Fields: name (str), base_url (str), api_key (str), space_id (str|null),
#         verify_ssl (bool, default true), per_page (int, default 100), max_pages (int, default 100)
KIBANAS=[]

# AlertManager instances: JSON array of AlertManager objects
# Fields: name (str), url (str), token (str|null), verify_ssl (bool, default true)
ALERTMANAGERS=[]
